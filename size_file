#include <stdio.h>
#include <stdlib.h>
#include <sys/stat.h>

int main(int argc, char *argv[]) {
    if (argc != 2) {
        printf("Использование: %s <имя_файла>\n", argv[0]);
        return 1;
    }
    
    struct stat file_stat;
    
    if (stat(argv[1], &file_stat) == -1) {
        perror("Ошибка");
        return 1;
    }
    
    printf("Размер файла '%s': %ld байт\n", argv[1], file_stat.st_size);
    
    return 0;
}
