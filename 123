#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <poll.h>
#include <fcntl.h>
#define TIMEOUT 5
#define BUFFER_SIZE 1024

int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Введите: %s <исходный_файл> <целевой_файл>\n", argv[0]);
        return 1;
    }
    

    int source_fd = open(argv[1], O_RDONLY);
    if (source_fd < 0) {
        perror("Ошибка открытия исходного файла");
        return 1;
    }
    

    FILE *dest = fopen(argv[2], "w");
    if (dest == NULL) {
        perror("Ошибка создания целевого файла");
        close(source_fd);
        return 1;
    }
    

    struct pollfd fds[1];
    fds[0].fd = source_fd;
    fds[0].events = POLLIN;
    
    char buffer[BUFFER_SIZE];
    int total_bytes = 0;
    
    int ret = poll(fds, 1, TIMEOUT * 1000);
        
    if (ret < 0) {
        perror("poll error");
        return 1;
    }
        
    if (ret == 0) {
        printf("Ожидание данных\n");
    }
        
        if (fds[0].revents & POLLIN) {
            ssize_t bytes = read(source_fd, buffer, sizeof(buffer));
            
            if (bytes > 0) {
                fwrite(buffer, 1, bytes, dest);
                total_bytes += bytes;
                printf("Прочитано %ld байт (всего: %d)\n", bytes, total_bytes);
                } 
            else {
                perror("read error");
                return 1;
            }
        }
        
        if (fds[0].revents & POLLERR) {
            printf("Ошибка при чтении файла\n");
            return 1;
        }
    
    close(source_fd);
    fclose(dest);
    
    printf("Копирование завершено\n");
    return 0;
}
