#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <poll.h>
#include <fcntl.h>
#include <sys/stat.h>

#define TIMEOUT 5
#define BUFFER_SIZE 1024

int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Введите: %s <исходный_файл> <целевой_файл>\n", argv[0]);
        return 1;
    }
    
    // Получаем размер исходного файла через stat
    struct stat file_stat;
    if (stat(argv[1], &file_stat) == -1) {
        perror("Ошибка получения информации о файле\n");
        return 1;
    }
    
    printf("Размер исходного файла '%s': %ld байт\n", argv[1], file_stat.st_size);
    
    // Открываем исходный файл
    int source_fd = open(argv[1], O_RDONLY);
    if (source_fd < 0) {
        perror("Ошибка открытия исходного файла\n");
        return 1;
    }
    
    // Открываем целевой файл
    FILE *dest = fopen(argv[2], "w");
    if (dest == NULL) {
        perror("Ошибка создания целевого файла\n");
        close(source_fd);
        return 1;
    }
    
    struct pollfd fds[1];
    fds[0].fd = source_fd;
    fds[0].events = POLLIN;
    
    char buffer[BUFFER_SIZE];
    int total_bytes = 0;
    int bytes_to_read = file_stat.st_size;
    
    // Копируем пока не прочитаем весь файл
    while (total_bytes < bytes_to_read) {
        int ret = poll(fds, 1, TIMEOUT * 1000);
        
        if (ret < 0) {
            perror("Ошибка с poll\n");
            break;
        }
        
        if (ret == 0) {
            printf("Таймаут: скопировано %d из %ld байт\n", total_bytes, file_stat.st_size);
            break;
        }
        
        if (fds[0].revents & POLLIN) {
            ssize_t bytes = read(source_fd, buffer, sizeof(buffer));
            
            if (bytes > 0) {
                fwrite(buffer, 1, bytes, dest);
                total_bytes += bytes;
                printf("Скопировано %ld байт (всего: %d из %ld)\n", 
                       bytes, total_bytes, file_stat.st_size);
            }
            else if (bytes == 0) 
                break;
            else {
                perror("read error\n");
                break;
            }
        }
        
        if (fds[0].revents & POLLERR) {
            printf("Ошибка при чтении файла\n");
            break;
        }
    }
    
    // Проверяем результат
    if (total_bytes == file_stat.st_size) 
        printf("Копирование завершено успешно\n", total_bytes);
    else 
        printf("Копирование завершено с ошибкой\n", total_bytes, file_stat.st_size);
    
    close(source_fd);
    fclose(dest);
    
    return 0;
}
