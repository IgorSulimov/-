#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/stat.h>

#define BUFFER_SIZE 1024

int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Введите: %s <исходный_файл> <целевой_файл>\n", argv[0]);
        return 1;
    }
    
    // Получаем размер исходного файла
    struct stat file_stat;
    if (stat(argv[1], &file_stat) == -1) {
        perror("Ошибка stat");
        return 1;
    }
    
    printf("Размер файла '%s': %ld байт\n", argv[1], file_stat.st_size);
    
    // Открываем файлы
    int source_fd = open(argv[1], O_RDONLY);
    if (source_fd < 0) {
        perror("Ошибка открытия исходного файла");
        return 1;
    }
    
    FILE *dest = fopen(argv[2], "w");
    if (dest == NULL) {
        perror("Ошибка создания целевого файла");
        close(source_fd);
        return 1;
    }
    
    // Копируем файл
    char buffer[BUFFER_SIZE];
    ssize_t bytes_read;
    int total = 0;
    
    while ((bytes_read = read(source_fd, buffer, BUFFER_SIZE)) > 0) {
        fwrite(buffer, 1, bytes_read, dest);
        total += bytes_read;
    }
    
    printf("Скопировано %d байт\n", total);
    
    close(source_fd);
    fclose(dest);
    
    return 0;
}
