int main() {
  int n;
  size_t size = 256;
  char line[size];

  while(true) {
    printf(" >>> ");
    fflush(stdout);

    get_line(line, size);
    
    if (strlen(line) == 0) continue;
    
    // Обработка !!
    if (strcmp(line, "!!") == 0) {
      char *last = get_from_history();
      if (last == NULL) {
        printf("Нет команд в истории\n");
        continue;
      }
      printf("%s\n", last);
      strcpy(line, last);
      free(last);
    }
    
    save_to_history(line);

    n = parse_commands(line, commands);
    printf("shell: command found: %s\n", commands[0].argv[0]);
    print_commands(n);
    fork_commands(n);
  }

  exit(EXIT_SUCCESS);
}
