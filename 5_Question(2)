#include "parser.h"
#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <fcntl.h>

#define READ 0
#define WRITE 1
#define HISTORY_FILE ".shell_history"

cmd_t commands[MAX_COMMANDS];

void save_to_history(const char *cmd) {
    FILE *f = fopen(HISTORY_FILE, "w");
    if (f) { fprintf(f, "%s\n", cmd); fclose(f); }
}

char* get_from_history() {
    FILE *f = fopen(HISTORY_FILE, "r");
    if (!f) return NULL;
    char *line = NULL;
    size_t len = 0;
    if (getline(&line, &len, f) == -1) { free(line); line = NULL; }
    fclose(f);
    if (line) { size_t l = strlen(line); if (l > 0 && line[l-1] == '\n') line[l-1] = '\0'; }
    return line;
}

void run_pipeline(int n) {
    int pipes[MAX_COMMANDS][2];
    
    // Создаём все pipe
    for (int i = 0; i < n - 1; i++) {
        if (pipe(pipes[i]) == -1) {
            perror("pipe");
            exit(1);
        }
    }
    
    // Создаём процессы
    for (int i = 0; i < n; i++) {
        pid_t pid = fork();
        
        if (pid == -1) {
            perror("fork");
            exit(1);
        }
        
        if (pid == 0) {
            // Дочерний процесс
            
            // Настройка ввода (не первый)
            if (i > 0) {
                dup2(pipes[i-1][READ], STDIN_FILENO);
            }
            
            // Настройка вывода (не последний)
            if (i < n - 1) {
                dup2(pipes[i][WRITE], STDOUT_FILENO);
            }
            
            // Закрываем все pipe
            for (int j = 0; j < n - 1; j++) {
                close(pipes[j][READ]);
                close(pipes[j][WRITE]);
            }
            
            // Запускаем команду
            execvp(commands[i].argv[0], commands[i].argv);
            fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
            exit(1);
        }
    }
    
    // Закрываем все pipe в родителе
    for (int i = 0; i < n - 1; i++) {
        close(pipes[i][READ]);
        close(pipes[i][WRITE]);
    }
    
    // Ждём все процессы
    for (int i = 0; i < n; i++) {
        wait(NULL);
    }
}

void read_line(char *buf, size_t size) {
    if (fgets(buf, size, stdin) == NULL) { printf("\n"); exit(0); }
    size_t len = strlen(buf);
    if (len > 0 && buf[len-1] == '\n') buf[len-1] = '\0';
}

int main() {
    char *line = malloc(1024);
    
    while (1) {
        printf(">>> ");
        fflush(stdout);
        
        read_line(line, 1024);
        if (strlen(line) == 0) continue;
        
        if (strcmp(line, "!!") == 0) {
            char *last = get_from_history();
            if (last == NULL) { printf("Нет команд в истории\n"); continue; }
            printf("%s\n", last);
            free(line);
            line = last;
        }
        
        save_to_history(line);
        
        int n = parse_commands(line, commands);
        if (n == 0) continue;
        
        if (n == 1 && strcmp(commands[0].argv[0], "exit") == 0) break;
        
        run_pipeline(n);
    }
    
    free(line);
    return 0;
}
