#include "parser.h"    // cmd_t, position_t, parse_commands()

#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>
#include <errno.h>
#include <stdlib.h>
#include <stdbool.h>
#include <fcntl.h>

#define READ  0
#define WRITE 1
#define MAX_COMMANDS 16

/**
 * Для простоты мы используем глобальный массив для хранения данных каждой команды в
 * конвейере команд.
 */
cmd_t commands[MAX_COMMANDS];

// Буфер для последней команды (только в памяти)
char *last_command = NULL;

/**
 *  Отладочная распечатка массива команд.
 */
void print_commands(int n) {
  for (int i = 0; i < n; i++) {
    printf("==> commands[%d]\n", i);
    printf("  pos = %s\n", position_to_string(commands[i].pos));
    printf("  in  = %d\n", commands[i].in);
    printf("  out = %d\n", commands[i].out);

    print_argv(commands[i].argv);
  }
}

/**
 * Возвращает true, если файловый дескриптор fd открыт. В противном случае возвращается false.
 */
int is_open(int fd) {
  return fcntl(fd, F_GETFL) != -1 || errno != EBADF;
}

void fork_error() {
  perror("fork() failed");
  exit(EXIT_FAILURE);
}

/**
 * Считывает командную строку от пользователя
 */
void get_line(char* buffer, size_t size) {
  size_t a = getline(&buffer, &size, stdin);
  buffer[strlen(buffer)-1] = '\0';
}

/**
 * ФУНКЦИЯ: запуск конвейера команд с использованием switch-case
 */
void fork_cmd(int n) {
  int pipes[MAX_COMMANDS][2];
  pid_t pids[MAX_COMMANDS];
  int num_pipes = n - 1;
  
  // ШАГ 1: Создаём все pipe
  for (int i = 0; i < num_pipes; i++) {
    if (pipe(pipes[i]) == -1) {
      perror("pipe failed");
      exit(EXIT_FAILURE);
    }
  }
  
  // ШАГ 1.5: ОБНОВЛЯЕМ in И out ДЛЯ КАЖДОЙ КОМАНДЫ
  for (int i = 0; i < n; i++) {
    // Если не первая команда → читаем из предыдущего pipe
    if (i > 0) {
      commands[i].in = pipes[i-1][READ];
    }
    // Если не последняя команда → пишем в следующий pipe
    if (i < n - 1) {
      commands[i].out = pipes[i][WRITE];
    }
  }
  
  // ШАГ 2: Создаём все дочерние процессы
  for (int i = 0; i < n; i++) {
    pid_t pid = fork();
    
    switch(pid) {
      case -1:
        fork_error();
        break;
        
      case 0: {
        // === ДОЧЕРНИЙ ПРОЦЕСС ===
        
        // Используем обновлённые in/out
        if (commands[i].in != -1 && commands[i].in != STDIN_FILENO) {
          dup2(commands[i].in, STDIN_FILENO);
          close(commands[i].in);
        }
        if (commands[i].out != -1 && commands[i].out != STDOUT_FILENO) {
          dup2(commands[i].out, STDOUT_FILENO);
          close(commands[i].out);
        }
        
        // Закрываем все pipe
        for (int j = 0; j < num_pipes; j++) {
          close(pipes[j][READ]);
          close(pipes[j][WRITE]);
        }
        
        // Запускаем команду
        execvp(commands[i].argv[0], commands[i].argv);
        
        fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
        exit(EXIT_FAILURE);
        break;
      }
        
      default:
        pids[i] = pid;
        break;
    }
  }
  
  // ШАГ 3: Родительский процесс закрывает все pipe
  for (int i = 0; i < num_pipes; i++) {
    close(pipes[i][READ]);
    close(pipes[i][WRITE]);
  }
  
  // ШАГ 4: Родительский процесс ждёт завершения всех детей
  for (int i = 0; i < n; i++) {
    wait(NULL);
  }
}

int main() {
  int n;
  size_t size = 256;
  char line[size];

  while(true) {
    printf(" >>> ");
    fflush(stdout);

    get_line(line, size);
    
    if (strlen(line) == 0) continue;
    
    // Обработка !! (используем сохранённую в last_command команду)
    if (strcmp(line, "!!") == 0) {
      if (last_command == NULL) {
        printf("Нет команд в истории\n");
        continue;
      }
      printf("%s\n", last_command);
      strcpy(line, last_command);
    }
    
    // Сохраняем команду в буфер (для !!)
    if (last_command != NULL) {
      free(last_command);
    }
    last_command = strdup(line);

    n = parse_commands(line, commands);
    
    if (n == 0) continue;
    
    printf("shell: command found: %s\n", commands[0].argv[0]);
    print_commands(n);
    
    fork_cmd(n);
  }

  // Очистка буфера при выходе
  if (last_command != NULL) {
    free(last_command);
  }

  exit(EXIT_SUCCESS);
}
