#include "parser.h"    // cmd_t, position_t, parse_commands()

#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>
#include <errno.h>
#include <stdlib.h>
#include <stdbool.h>
#include <fcntl.h>

#define READ  0
#define WRITE 1
#define HISTORY_FILE ".shell_history"

cmd_t commands[MAX_COMMANDS];

// ==================== ФУНКЦИИ ДЛЯ ИСТОРИИ (!!) ====================

// Сохраняет команду в файл (перезаписывает)
void save_command_to_file(const char *command) {
    FILE *file = fopen(HISTORY_FILE, "w");
    if (file == NULL) {
        return;
    }
    fprintf(file, "%s\n", command);
    fclose(file);
}

// Читает последнюю команду из файла
char* read_last_command_from_file() {
    FILE *file = fopen(HISTORY_FILE, "r");
    if (file == NULL) {
        return NULL;
    }
    
    char *line = NULL;
    size_t len = 0;
    ssize_t read;
    
    read = getline(&line, &len, file);
    fclose(file);
    
    if (read == -1) {
        free(line);
        return NULL;
    }
    
    // Удаляем символ новой строки
    size_t line_len = strlen(line);
    if (line_len > 0 && line[line_len-1] == '\n') {
        line[line_len-1] = '\0';
    }
    
    return line;
}

// ==================== ФУНКЦИИ ДЛЯ PIPE (КОНВЕЙЕР) ====================

// Создаёт канал (pipe)
void create_pipe(int pipefd[2]) {
    if (pipe(pipefd) == -1) {
        perror("pipe() failed");
        exit(EXIT_FAILURE);
    }
}

// Настраивает перенаправление ввода/вывода для команды
void setup_redirection(int i, int prev_pipe[2], int next_pipe[2], int n) {
    
    // НАСТРОЙКА ВВОДА (откуда читать)
    if (commands[i].in != -1) {
        // Parser уже открыл файл и положил дескриптор в commands[i].in
        dup2(commands[i].in, STDIN_FILENO);
        close(commands[i].in);
    } 
    else if (i > 0 && prev_pipe != NULL) {
        // Чтение из предыдущего канала (для команд B, C, ...)
        dup2(prev_pipe[READ], STDIN_FILENO);
    }
    
    // НАСТРОЙКА ВЫВОДА (куда писать)
    if (commands[i].out != -1) {
        // Parser уже открыл файл и положил дескриптор в commands[i].out
        dup2(commands[i].out, STDOUT_FILENO);
        close(commands[i].out);
    } 
    else if (i < n - 1 && next_pipe != NULL) {
        // Запись в следующий канал (для команд A, B, ...)
        dup2(next_pipe[WRITE], STDOUT_FILENO);
    }
}

// Закрывает ненужные концы каналов
void close_pipe_fds(int prev_pipe[2], int next_pipe[2]) {
    if (prev_pipe != NULL) {
        close(prev_pipe[READ]);
        close(prev_pipe[WRITE]);
    }
    if (next_pipe != NULL) {
        close(next_pipe[READ]);
        close(next_pipe[WRITE]);
    }
}

// Создаёт дочерний процесс для одной команды
void fork_cmd(int i, int prev_pipe[2], int next_pipe[2], int n) {
    pid_t pid = fork();
    
    if (pid == -1) {
        perror("fork() failed");
        exit(EXIT_FAILURE);
    }
    
    if (pid == 0) {
        // ДОЧЕРНИЙ ПРОЦЕСС
        
        // Настраиваем откуда читать и куда писать
        setup_redirection(i, prev_pipe, next_pipe, n);
        
        // Закрываем ненужные концы каналов
        close_pipe_fds(prev_pipe, next_pipe);
        
        // Выполняем команду
        execvp(commands[i].argv[0], commands[i].argv);
        
        // Если дошли сюда - команда не найдена
        fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
        exit(EXIT_FAILURE);
    }
    
    // РОДИТЕЛЬСКИЙ ПРОЦЕСС
    
    // Закрываем каналы в родителе (они больше не нужны)
    if (prev_pipe != NULL) {
        close(prev_pipe[READ]);
        close(prev_pipe[WRITE]);
    }
}

// Создаёт конвейер из n команд
void fork_commands(int n) {
    int prev_pipe[2];
    int next_pipe[2];
    bool has_prev_pipe = false;
    
    for (int i = 0; i < n; i++) {
        // Создаём новый канал для связи со следующей командой (если не последняя)
        if (i < n - 1 && commands[i].out == -1) {
            create_pipe(next_pipe);
        }
        
        // Запускаем команду с нужными каналами
        fork_cmd(i, 
                 has_prev_pipe ? prev_pipe : NULL,  // откуда читать
                 (i < n - 1 && commands[i].out == -1) ? next_pipe : NULL,  // куда писать
                 n);
        
        // Закрываем предыдущий канал
        if (has_prev_pipe) {
            close(prev_pipe[READ]);
            close(prev_pipe[WRITE]);
        }
        
        // Сохраняем текущий канал как предыдущий для следующей команды
        if (i < n - 1 && commands[i].out == -1) {
            prev_pipe[READ] = next_pipe[READ];
            prev_pipe[WRITE] = next_pipe[WRITE];
            has_prev_pipe = true;
        } else {
            has_prev_pipe = false;
        }
    }
    
    // Закрываем последний канал, если он есть
    if (has_prev_pipe) {
        close(prev_pipe[READ]);
        close(prev_pipe[WRITE]);
    }
}

// ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================

// Читает строку от пользователя
void get_line(char* buffer, size_t size) {
    if (fgets(buffer, size, stdin) == NULL) {
        printf("\n");
        exit(EXIT_SUCCESS);
    }
    size_t len = strlen(buffer);
    if (len > 0 && buffer[len-1] == '\n') {
        buffer[len-1] = '\0';
    }
}

// Ожидает завершения всех дочерних процессов
void wait_for_all_cmds(int n) {
    int status;
    pid_t pid;
    
    while ((pid = wait(&status)) > 0) {
        // Просто ждём все процессы
    }
}

// Обрабатывает специальную команду !!
bool handle_special_commands(char **line_ptr) {
    char *line = *line_ptr;
    
    if (strcmp(line, "!!") == 0) {
        char *last_command = read_last_command_from_file();
        
        if (last_command == NULL) {
            printf("Нет команд в истории\n");
            return true;
        }
        
        // Выводим команду на экран
        printf("%s\n", last_command);
        
        // Заменяем !! на реальную команду
        free(*line_ptr);
        *line_ptr = last_command;
        
        return false;  // Продолжаем выполнение
    }
    
    return false;
}

// Отладочная печать
void print_commands(int n) {
    for (int i = 0; i < n; i++) {
        printf("==> commands[%d]\n", i);
        printf("  pos = %s\n", position_to_string(commands[i].pos));
        printf("  in  = %d\n", commands[i].in);
        printf("  out = %d\n", commands[i].out);
        print_argv(commands[i].argv);
    }
}

// ==================== ГЛАВНАЯ ФУНКЦИЯ ====================

int main() {
    size_t size = 1024;
    char *line = malloc(size);
    
    if (line == NULL) {
        fprintf(stderr, "Memory allocation failed\n");
        exit(EXIT_FAILURE);
    }
    
    while(true) {
        printf(" >>> ");
        fflush(stdout);
        
        get_line(line, size);
        
        if (strlen(line) == 0) continue;
        
        // Обрабатываем !!
        if (handle_special_commands(&line)) {
            continue;
        }
        
        // Сохраняем команду в файл истории
        save_command_to_file(line);
        
        // Разбираем команду на части
        int n = parse_commands(line, commands);
        
        if (n == 0) continue;
        
        // Отладочный вывод
        printf("shell: %d command(s) found in pipeline\n", n);
        print_commands(n);
        
        // Запускаем конвейер
        fork_commands(n);
        
        // Ждём завершения всех команд
        wait_for_all_cmds(n);
    }
    
    free(line);
    exit(EXIT_SUCCESS);
}
