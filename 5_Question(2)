#include "parser.h"    // cmd_t, position_t, parse_commands()

#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>
#include <errno.h>
#include <stdlib.h>
#include <stdbool.h>
#include <fcntl.h>

#define READ  0
#define WRITE 1
#define MAX_COMMANDS 16

/**
 * Для простоты мы используем глобальный массив для хранения данных каждой команды в
 * конвейере команд.
 */
cmd_t commands[MAX_COMMANDS];

// Буфер для последней команды (только в памяти)
char *last_command = NULL;

/**
 *  Отладочная распечатка массива команд.
 */
void print_commands(int n) {
  for (int i = 0; i < n; i++) {
    printf("==> commands[%d]\n", i);
    printf("  pos = %s\n", position_to_string(commands[i].pos));
    printf("  in  = %d\n", commands[i].in);
    printf("  out = %d\n", commands[i].out);
    print_argv(commands[i].argv);
  }
}

/**
 * Возвращает true, если файловый дескриптор fd открыт. В противном случае возвращается false.
 */
int is_open(int fd) {
  return fcntl(fd, F_GETFL) != -1 || errno != EBADF;
}

void fork_error() {
  perror("fork() failed");
  exit(EXIT_FAILURE);
}

/**
 * Считывает командную строку от пользователя
 */
void get_line(char* buffer, size_t size) {
  size_t a = getline(&buffer, &size, stdin);
  buffer[strlen(buffer)-1] = '\0';
}

/**
 *  fork процесса для команды с индексом i в конвейере команд. Если необходимо,
 *  создайте новый канал и обновите дескрипторы in и out для команды.
 */
void fork_cmd(int i, int n) {
  static int pipes[MAX_COMMANDS][2];  // Статические pipe для всех команд
  static int num_pipes = -1;          // Количество созданных pipe
  static int pipes_created = 0;       // Флаг, что pipe уже созданы
  pid_t pid;
  
  // При первом вызове (i == 0) создаём все необходимые pipe
  if (i == 0 && !pipes_created) {
    num_pipes = n - 1;
    for (int j = 0; j < num_pipes; j++) {
      if (pipe(pipes[j]) == -1) {
        perror("pipe failed");
        exit(EXIT_FAILURE);
      }
    }
    pipes_created = 1;
  }
  
  switch (pid = fork()) {
    case -1:
      fork_error();
      
    case 0: {
      // === ДОЧЕРНИЙ ПРОЦЕСС ===
      
      // Обновляем дескрипторы in и out для команды i
      // Если команда не первая и нет перенаправления из файла
      if (i > 0 && commands[i].in == -1) {
        commands[i].in = pipes[i-1][READ];  // Читаем из предыдущего pipe
      }
      
      // Если команда не последняя и нет перенаправления в файл
      if (i < n - 1 && commands[i].out == -1) {
        commands[i].out = pipes[i][WRITE];  // Пишем в следующий pipe
      }
      
      // Перенаправление ввода (если нужно)
      if (commands[i].in != -1 && commands[i].in != STDIN_FILENO) {
        dup2(commands[i].in, STDIN_FILENO);
        if (commands[i].in > 2) {
          close(commands[i].in);
        }
      }
      
      // Перенаправление вывода (если нужно)
      if (commands[i].out != -1 && commands[i].out != STDOUT_FILENO) {
        dup2(commands[i].out, STDOUT_FILENO);
        if (commands[i].out > 2) {
          close(commands[i].out);
        }
      }
      
      // Закрываем все pipe в дочернем процессе
      for (int j = 0; j < num_pipes; j++) {
        close(pipes[j][READ]);
        close(pipes[j][WRITE]);
      }
      
      // Выполнение команды
      execvp(commands[i].argv[0], commands[i].argv);
      
      fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
      exit(EXIT_FAILURE);
      break;
    }
      
    default:
      // Родительский процесс - ничего не делаем, просто возвращаемся
      break;
  }
}

/**
 *  fork одного дочернего процесса для каждой команды в конвейере команд.
 */
void fork_commands(int n) {
  for (int i = 0; i < n; i++) {
    fork_cmd(i, n);
  }
  
  // Закрываем все pipe в родительском процессе
  // (pipes хранятся статически в fork_cmd, доступа к ним нет)
  // Поэтому pipe закрываются в родителе после fork_commands?
}

int main() {
  int n;
  size_t size = 256;
  char line[size];

  while(true) {
    printf(" >>> ");
    fflush(stdout);

    get_line(line, size);
    
    if (strlen(line) == 0) continue;
    
    // Обработка !!
    if (strcmp(line, "!!") == 0) {
      if (last_command == NULL) {
        printf("Нет команд в истории\n");
        continue;
      }
      printf("%s\n", last_command);
      strcpy(line, last_command);
    }
    
    // Сохраняем команду в буфер
    if (last_command != NULL) {
      free(last_command);
    }
    last_command = strdup(line);

    n = parse_commands(line, commands);
    
    if (n == 0) continue;
    
    printf("shell: command found: %s\n", commands[0].argv[0]);
    print_commands(n);
    
    fork_commands(n);
    
    // Ждём завершения всех дочерних процессов
    for (int i = 0; i < n; i++) {
      wait(NULL);
    }
  }

  if (last_command != NULL) {
    free(last_command);
  }

  exit(EXIT_SUCCESS);
}
