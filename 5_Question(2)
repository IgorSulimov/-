#define READ  0
#define WRITE 1
#define HISTORY_FILE ".shell_history"
#define MAX_COMMANDS 16

cmd_t commands[MAX_COMMANDS];
char *last_command_line = NULL;

void print_commands(int n) {
  for (int i = 0; i < n; i++) {
    printf("==> commands[%d]\n", i);
    printf("  pos = %s\n", position_to_string(commands[i].pos));
    printf("  in  = %d\n", commands[i].in);
    printf("  out = %d\n", commands[i].out);
    print_argv(commands[i].argv);
  }
}

int is_open(int fd) {
  return fcntl(fd, F_GETFL) != -1 || errno != EBADF;
}

void fork_error() {
  perror("fork() failed");
  exit(EXIT_FAILURE);
}

void save_to_history(const char *cmd) {
  FILE *f = fopen(HISTORY_FILE, "w");
  if (f) {
    fprintf(f, "%s\n", cmd);
    fclose(f);
  }
}

char* get_from_history() {
  FILE *f = fopen(HISTORY_FILE, "r");
  if (!f) return NULL;
  
  char *line = NULL;
  size_t len = 0;
  if (getline(&line, &len, f) == -1) {
    free(line);
    line = NULL;
  }
  fclose(f);
  
  if (line) {
    size_t l = strlen(line);
    if (l > 0 && line[l-1] == '\n') line[l-1] = '\0';
  }
  return line;
}

/**
 * ГЛАВНАЯ ФУНКЦИЯ - запуск конвейера
 */
void fork_commands(int n) {
  int pipes[MAX_COMMANDS][2];
  
  // Создаём все pipe (n-1 штук)
  for (int i = 0; i < n - 1; i++) {
    if (pipe(pipes[i]) == -1) {
      perror("pipe failed");
      exit(EXIT_FAILURE);
    }
  }
  
  // Создаём дочерние процессы
  for (int i = 0; i < n; i++) {
    pid_t pid = fork();
    
    if (pid == -1) {
      fork_error();
    }
    
    if (pid == 0) {
      // === ДОЧЕРНИЙ ПРОЦЕСС ===
      
      // Перенаправление ввода (не для первой команды)
      if (i > 0) {
        dup2(pipes[i-1][READ], STDIN_FILENO);
      }
      
      // Перенаправление вывода (не для последней команды)
      if (i < n - 1) {
        dup2(pipes[i][WRITE], STDOUT_FILENO);
      }
      
      // Закрываем все pipe в дочернем процессе
      for (int j = 0; j < n - 1; j++) {
        close(pipes[j][READ]);
        close(pipes[j][WRITE]);
      }
      
      // Перенаправление из файлов (если указаны)
      if (commands[i].in != -1) {
        dup2(commands[i].in, STDIN_FILENO);
        close(commands[i].in);
      }
      if (commands[i].out != -1) {
        dup2(commands[i].out, STDOUT_FILENO);
        close(commands[i].out);
      }
      
      // Запускаем команду
      execvp(commands[i].argv[0], commands[i].argv);
      
      // Если сюда дошли - команда не найдена
      fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
      exit(EXIT_FAILURE);
    }
  }
  
  // === РОДИТЕЛЬСКИЙ ПРОЦЕСС ===
  
  // Закрываем все pipe в родителе
  for (int i = 0; i < n - 1; i++) {
    close(pipes[i][READ]);
    close(pipes[i][WRITE]);
  }
  
  // Ждём завершения всех дочерних процессов
  for (int i = 0; i < n; i++) {
    wait(NULL);
  }
}

void get_line(char* buffer, size_t size) {
  if (fgets(buffer, size, stdin) == NULL) {
    printf("\n");
    exit(EXIT_SUCCESS);
  }
  size_t len = strlen(buffer);
  if (len > 0 && buffer[len-1] == '\n') {
    buffer[len-1] = '\0';
  }
}

