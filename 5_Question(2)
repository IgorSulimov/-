#include "parser.h"    // cmd_t, position_t, parse_commands()

#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>
#include <errno.h>
#include <stdlib.h>
#include <stdbool.h>
#include <fcntl.h>

#define READ  0
#define WRITE 1
#define MAX_COMMANDS 16

/**
 * Для простоты мы используем глобальный массив для хранения данных каждой команды в
 * конвейере команд.
 */
cmd_t commands[MAX_COMMANDS];

// Буфер для последней команды (только в памяти)
char *last_command = NULL;

/**
 *  Отладочная распечатка массива команд.
 */
void print_commands(int n) {
  for (int i = 0; i < n; i++) {
    printf("==> commands[%d]\n", i);
    printf("  pos = %s\n", position_to_string(commands[i].pos));
    printf("  in  = %d\n", commands[i].in);
    printf("  out = %d\n", commands[i].out);

    print_argv(commands[i].argv);
  }
}

/**
 * Возвращает true, если файловый дескриптор fd открыт. В противном случае возвращается false.
 */
int is_open(int fd) {
  return fcntl(fd, F_GETFL) != -1 || errno != EBADF;
}

void fork_error() {
  perror("fork() failed");
  exit(EXIT_FAILURE);
}

// Сохранение команды в буфер
void save_to_buffer(const char *cmd) {
  if (last_command != NULL) {
    free(last_command);
  }
  last_command = strdup(cmd);
}

// Получение последней команды из буфера
char* get_from_buffer() {
  if (last_command == NULL) {
    return NULL;
  }
  return strdup(last_command);
}

/**
 * ЕДИНАЯ ФУНКЦИЯ: запуск конвейера команд
 */
void run_pipeline(int n) {
  int pipes[MAX_COMMANDS][2];
  pid_t pids[MAX_COMMANDS];
  int num_pipes = n - 1;
  
  // ШАГ 1: Создаём все pipe (n-1 штук)
  for (int i = 0; i < num_pipes; i++) {
    if (pipe(pipes[i]) == -1) {
      perror("pipe failed");
      exit(EXIT_FAILURE);
    }
  }
  
  // ШАГ 2: Создаём все дочерние процессы
  for (int i = 0; i < n; i++) {
    pids[i] = fork();
    
    if (pids[i] == -1) {
      fork_error();
    }
    
    if (pids[i] == 0) {
      // === ДОЧЕРНИЙ ПРОЦЕСС ===
      
      // Перенаправление ввода (не для первой команды)
      if (i > 0) {
        dup2(pipes[i-1][READ], STDIN_FILENO);
      }
      
      // Перенаправление вывода (не для последней команды)
      if (i < n - 1) {
        dup2(pipes[i][WRITE], STDOUT_FILENO);
      }
      
      // Закрываем все pipe в дочернем процессе
      for (int j = 0; j < num_pipes; j++) {
        close(pipes[j][READ]);
        close(pipes[j][WRITE]);
      }
      
      // Перенаправление из файлов (если указаны)
      if (commands[i].in != -1) {
        dup2(commands[i].in, STDIN_FILENO);
        if (commands[i].in > 2) {
          close(commands[i].in);
        }
      }
      if (commands[i].out != -1) {
        dup2(commands[i].out, STDOUT_FILENO);
        if (commands[i].out > 2) {
          close(commands[i].out);
        }
      }
      
      // Запускаем команду
      execvp(commands[i].argv[0], commands[i].argv);
      
      // Если сюда дошли - команда не найдена
      fprintf(stderr, "shell: command not found: %s\n", commands[i].argv[0]);
      exit(EXIT_FAILURE);
    }
  }
  
  // ШАГ 3: Родительский процесс закрывает все pipe
  for (int i = 0; i < num_pipes; i++) {
    close(pipes[i][READ]);
    close(pipes[i][WRITE]);
  }
  
  // ШАГ 4: Родительский процесс ждёт завершения всех детей
  for (int i = 0; i < n; i++) {
    wait(NULL);
  }
}

/**
 * Считывает командную строку от пользователя
 */
void get_line(char* buffer, size_t size) {
  if (fgets(buffer, size, stdin) == NULL) {
    printf("\n");
    exit(EXIT_SUCCESS);
  }
  size_t len = strlen(buffer);
  if (len > 0 && buffer[len-1] == '\n') {
    buffer[len-1] = '\0';
  }
}

int main() {
  int n;
  size_t size = 256;
  char line[size];

  while(true) {
    printf(" >>> ");
    fflush(stdout);

    get_line(line, size);
    
    if (strlen(line) == 0) continue;
    
    // Обработка !!
    if (strcmp(line, "!!") == 0) {
      char *last = get_from_buffer();
      if (last == NULL) {
        printf("Нет команд в истории\n");
        continue;
      }
      printf("%s\n", last);
      strcpy(line, last);
      free(last);
    }
    
    // Сохраняем команду в буфер
    save_to_buffer(line);

    n = parse_commands(line, commands);
    
    if (n == 0) continue;
    
    printf("shell: command found: %s\n", commands[0].argv[0]);
    print_commands(n);
    
    // Запускаем конвейер (одна функция вместо fork_commands + fork_cmd)
    run_pipeline(n);
  }

  // Очистка буфера при выходе
  if (last_command != NULL) {
    free(last_command);
  }

  exit(EXIT_SUCCESS);
}
