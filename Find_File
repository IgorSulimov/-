#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <dirent.h>

int main(int argc, char *argv[]) {
        if (argc != 3) {
        printf("Введите: %s <каталог> <файл>\n", argv[0]);
        return 1;
    }
    
    DIR *dir = opendir(argv[1]);
    if (!dir) return 1;
    
    struct dirent *entry;
    while ((entry = readdir(dir))) {
        if (strcmp(entry->d_name, argv[2]) == 0) {
            closedir(dir);
            printf("Файл %s НАЙДЕН\n",entry->d_name);
            return 0;
        }
    }
    printf("Файла %s Нет в данной дирректории \n",argv[2]);
    closedir(dir);
    return 0;
}
