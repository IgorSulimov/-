#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <dirent.h>

int main(int argc, char *argv[]) {
    if (argc != 3) return 1;
    
    DIR *dir = opendir(argv[1]);
    if (!dir) return 1;
    
    struct dirent *entry;
    while ((entry = readdir(dir))) {
        if (strcmp(entry->d_name, argv[2]) == 0) {
            closedir(dir);
            printf("yes\n");
            return 0;
        }
    }
    
    closedir(dir);
    printf("no\n");
    return 0;
}
