#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <dirent.h>
#include <sys/stat.h>

int main(int argc, char *argv[]) {
    // Проверка аргументов командной строки
    if (argc != 3) {
        printf("Использование: %s <каталог> <имя_файла>\n", argv[0]);
        printf("Пример: %s /home/user document.txt\n", argv[0]);
        return 1;
    }

    const char *directory = argv[1];  // Путь к каталогу
    const char *filename = argv[2];    // Имя искомого файла
    
    printf("Поиск файла '%s' в каталоге '%s'...\n", filename, directory);
    
    // Открываем каталог
    DIR *dir = opendir(directory);
    if (dir == NULL) {
        printf("Ошибка: Не удалось открыть каталог '%s'\n", directory);
        return 1;
    }
    
    struct dirent *entry;
    int found = 0;
    int file_count = 0;
    
    // Читаем содержимое каталога
    while ((entry = readdir(dir)) != NULL) {
        // Пропускаем текущий и родительский каталоги
        if (strcmp(entry->d_name, ".") == 0 || strcmp(entry->d_name, "..") == 0) {
            continue;
        }
        
        file_count++;
        
        // Сравниваем имя файла с искомым
        if (strcmp(entry->d_name, filename) == 0) {
            found = 1;
            
            // Для получения дополнительной информации используем stat
            char full_path[1024];
            snprintf(full_path, sizeof(full_path), "%s/%s", directory, filename);
            
            struct stat file_stat;
            if (stat(full_path, &file_stat) == 0) {
                printf("\n✅ Файл НАЙДЕН!\n");
                printf("   Полный путь: %s\n", full_path);
                printf("   Размер: %ld байт\n", file_stat.st_size);
                printf("   Права доступа: %o\n", file_stat.st_mode & 0777);
            } else {
                printf("\n✅ Файл '%s' найден в каталоге '%s'\n", filename, directory);
            }
        }
    }
    
    // Закрываем каталог
    closedir(dir);
    
    // Выводим результат
    if (found) {
        printf("\n✅ Файл '%s' присутствует в каталоге '%s'\n", filename, directory);
    } else {
        printf("\n❌ Файл '%s' НЕ найден в каталоге '%s'\n", filename, directory);
        printf("   В каталоге найдено %d других файлов/папок\n", file_count);
    }
    
    return 0;
}
