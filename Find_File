#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <dirent.h>
#include <errno.h>

int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Использование: %s <каталог> <файл>\n", argv[0]);
        return 1;
    }
    
    printf("Аргумент 1 (каталог): '%s'\n", argv[1]);
    printf("Аргумент 2 (файл): '%s'\n", argv[2]);
    
    // Проверка длины аргументов
    printf("Длина имени каталога: %ld\n", strlen(argv[1]));
    printf("Длина имени файла: %ld\n", strlen(argv[2]));
    
    DIR *dir = opendir(argv[1]);
    if (dir == NULL) {
        printf("opendir вернул NULL\n");
        printf("errno: %d (%s)\n", errno, strerror(errno));
        return 1;
    }
    
    printf("Каталог успешно открыт\n");
    
    struct dirent *entry;
    int found = 0;
    int counter = 0;
    
    printf("\nСодержимое каталога:\n");
    while ((entry = readdir(dir)) != NULL) {
        counter++;
        printf("%d: '%s' (длина: %ld)\n", counter, entry->d_name, strlen(entry->d_name));
        
        if (strcmp(entry->d_name, argv[2]) == 0) {
            printf("  >>> СОВПАДЕНИЕ НАЙДЕНО! <<<\n");
            found = 1;
        }
    }
    
    printf("\nВсего прочитано записей: %d\n", counter);
    
    if (counter == 0) {
        printf("ВНИМАНИЕ: Каталог пуст или не читается\n");
    }
    
    closedir(dir);
    
    if (found) {
        printf("\n✅ РЕЗУЛЬТАТ: Файл НАЙДЕН\n");
    } else {
        printf("\n❌ РЕЗУЛЬТАТ: Файл НЕ НАЙДЕН\n");
    }
    
    return 0;
}
