#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <poll.h>
#include <fcntl.h>

#define BUFFER_SIZE 4096

int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Использование: %s <исходный_файл> <целевой_файл>\n", argv[0]);
        return 1;
    }
    
    // Открываем исходный файл
    int source_fd = open(argv[1], O_RDONLY);
    if (source_fd < 0) {
        perror("Ошибка открытия исходного файла");
        return 1;
    }
    
    // Открываем целевой файл
    FILE *dest = fopen(argv[2], "w");
    if (dest == NULL) {
        perror("Ошибка создания целевого файла");
        close(source_fd);
        return 1;
    }
    
    // Настраиваем poll
    struct pollfd fds[1];
    fds[0].fd = source_fd;
    fds[0].events = POLLIN;
    
    char buffer[BUFFER_SIZE];
    int total_bytes = 0;
    
    printf("Копирование с использованием poll()...\n");
    
    while (1) {
        int ret = poll(fds, 1, 1000); // 1 секунда таймаут
        
        if (ret < 0) {
            perror("poll error");
            break;
        }
        
        if (ret == 0) {
            printf("Ожидание данных... (скопировано %d байт)\n", total_bytes);
            continue;
        }
        
        if (fds[0].revents & POLLIN) {
            ssize_t bytes = read(source_fd, buffer, sizeof(buffer));
            
            if (bytes > 0) {
                fwrite(buffer, 1, bytes, dest);
                total_bytes += bytes;
                printf("Прочитано %ld байт (всего: %d)\n", bytes, total_bytes);
            } else if (bytes == 0) {
                printf("Конец файла. Скопировано %d байт\n", total_bytes);
                break;
            } else {
                perror("read error");
                break;
            }
        }
        
        if (fds[0].revents & POLLERR) {
            printf("Ошибка при чтении файла\n");
            break;
        }
    }
    
    close(source_fd);
    fclose(dest);
    
    printf("Копирование завершено!\n");
    return 0;
}
