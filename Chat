#include <stdio.h>
#include <string.h>
#include <semaphore>
#include <thread>
#include <chrono>
#include <iostream>
#include <vector>
using namespace std;
#define MAX_MSG 256
#define FILE_NAME "chat.txt"

std::counting_semaphore<1> sem_write(1);
std::counting_semaphore<1> sem_read(0);
int user_id;
void write();
void read();

void chat()
{
    thread th_read(read);
    thread th_write(write);

    th_read.join();  
    th_write.join();

}
void create_chat_file() 
{
    FILE* file;
    fopen_s(&file,FILE_NAME, "w"); 
    if (file != NULL) 
    {
        printf("Файл чата создан\n");
        fclose(file);
    }
    else 
    {
        printf("Ошибка создания файла чата\n");
    }
}

void read() {
    char buffer[MAX_MSG];
    FILE* file;
    long last_pos = 0;

    while (1) 
    {
        sem_read.acquire();

        fopen_s(&file, FILE_NAME, "r");
        if (file != NULL) {

            fseek(file, last_pos, SEEK_SET);


            while (fgets(buffer, MAX_MSG, file) != NULL) {
                buffer[strcspn(buffer, "\n")] = 0;
                printf("\nПрочитано: %s\n", buffer);
            }


            last_pos = ftell(file);
            fclose(file);
        }

        sem_write.release();
    }
}

void write()
{
    char input[MAX_MSG];
    FILE* file;

    while (1) {
        sem_write.acquire();

        printf("Введите текст:");
        fgets(input, MAX_MSG, stdin);
        input[strcspn(input, "\n")] = 0;

        fopen_s(&file, FILE_NAME, "a");
        if (file != NULL) {
            fprintf(file, "%s\n", input);
            fclose(file);
        }

        if (strcmp(input, "exit") == 0) {
            exit(0);
            break;
        }

        sem_read.release();
    }
}

int main() 
{
    setlocale(LC_ALL, "Russian");
    create_chat_file();

    printf("Для выхода введите 'exit'\n\n");

    chat();

    return 0;
}
